# Strava OAuth — get credentials at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Garmin OAuth — get credentials at https://developer.garmin.com
GARMIN_CONSUMER_KEY=your_garmin_consumer_key
GARMIN_CONSUMER_SECRET=your_garmin_consumer_secret

# App URLs (change for production)
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200

# JWT — use a long random hex string in production
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRATION=86400000

# Database
POSTGRES_DB=runhub
POSTGRES_USER=runhub
POSTGRES_PASSWORD=runhub123

# Google Drive API — get key at https://console.cloud.google.com
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key
